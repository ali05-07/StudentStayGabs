<resources>
    <!-- Simple Theme to ensure it launches and maintains Cream/Burgundy colors -->
    <style name="Theme.Stay" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/burgundy</item>
        <item name="colorPrimaryVariant">@color/burgundy_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/burgundy</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/background_cream</item>
        <item name="android:statusBarColor">@color/burgundy_dark</item>
    </style>
</resources>